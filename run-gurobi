#bin/bash
if [ $# -eq 0 ]; then
    echo "No arguments provided. Please provide the name of the python file to run."
    exit 1
fi

if [ ! -d "venv" ]; then
    python -m venv venv
fi

source venv/bin/activate
python -m pip install pipreqs

pipreqs . --force

python -m pip install gurobipy
python -m pip install -r requirements.txt
python $1
